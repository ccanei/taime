# Dependências
node_modules/
taime-web/node_modules/

# Variáveis de ambiente — NUNCA subir para o GitHub
.env
.env.local
taime-web/.env.local
*.env

# Build
taime-web/.next/
taime-web/out/

# Logs e progresso do batch
batch-progress.json
batch-periods.json

# Sistema
.DS_Store
*.log
.vercel

# Backups manuais
taime-web-BACKUP-*/

# Claude Code settings — local-only, podem conter permissões/contexto sensível
# (Glob `.claude/*` em vez de `.claude/` para permitir re-incluir subdirs
# específicos via negação. Diretório excluído com `/` final impede negação.)
.claude/*
# Exceção: skills do projeto são versionadas (compartilhadas com o time)
!.claude/skills/
!.claude/skills/**

# Output do gerador de posts LinkedIn — drafts locais, não versionar
output/

# Lockfile raiz — Next.js usa apenas taime-web/package-lock.json
package-lock.json
