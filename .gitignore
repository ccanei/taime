# Dependências
node_modules/
taime-web/node_modules/

# Variáveis de ambiente — NUNCA subir para o GitHub
.env
.env.local
taime-web/.env.local
*.env

# Build
taime-web/.next/
taime-web/out/

# Logs e progresso do batch
batch-progress.json
batch-periods.json

# Backups de progresso e logs de execucao de batch (descartaveis)
*.bak
batch-*.log
gen-*.log
teste-*.log
nohup.out

# Sistema
.DS_Store
*.log
.vercel

# Backups manuais
taime-web-BACKUP-*/

# Claude Code settings — local-only, podem conter permissões/contexto sensível
# (Glob `.claude/*` em vez de `.claude/` para permitir re-incluir subdirs
# específicos via negação. Diretório excluído com `/` final impede negação.)
.claude/*
# Exceção: skills do projeto são versionadas (compartilhadas com o time)
!.claude/skills/
!.claude/skills/**

# Output do gerador de posts LinkedIn — drafts locais, não versionar
output/

# Lockfile raiz — Next.js usa apenas taime-web/package-lock.json
package-lock.json

# Scripts descartáveis de tarefa pontual (revalidação, batch ad-hoc,
# inspeções one-off). Convenção de nome para serem ignorados:
check-*.ts
cleanup-*.ts
cost-*.ts
inspect-*.ts
regen-*.sh
batch-2*.sh
analyze-2*.ts
analyze-signals-debug.ts
find-pending-*.ts
get-report-ids.ts
patch-status.ts
restore-published-at.ts
test-judge-*.sh
pipeline-2*.sh
check-state-*.ts
