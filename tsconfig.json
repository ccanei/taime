{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "commonjs",
    "lib":               ["ES2022"],
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "outDir":            "dist",
    "resolveJsonModule": true
  },
  "include": ["*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
